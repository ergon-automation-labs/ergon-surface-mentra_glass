# Mentra Glass Pillar Configuration
# Copy to salt pillar location and customize for your environment
# Example: /srv/pillar/mentra_glass.sls

mentra_glass:
  # MentraOS API key for glass integration
  api_key: 'your_api_key_here'

  # Deployment settings
  repo_url: 'https://github.com/yourusername/ergon-surface-mentra_glass-elixir.git'
  branch: 'main'

  # Application port (behind nginx reverse proxy)
  port: 50000

  # SSL certificate paths (if using nginx)
  ssl_cert: '/etc/letsencrypt/live/mentra-glass.yourdomain.com/fullchain.pem'
  ssl_key: '/etc/letsencrypt/live/mentra-glass.yourdomain.com/privkey.pem'

  # Domain configuration
  domain: 'mentra-glass.yourdomain.com'

nats:
  # NATS connection for Bot Army integration
  primary_host: 'localhost'
  primary_port: 4222
  secondary_host: 'localhost'
  secondary_port: 14223
  background_host: 'localhost'
  background_port: 14224
